{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],

    "types": ["node", "@playwright/test"],

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "outDir": "./dist",
    "rootDir": "./",

    "noEmit": true
  },

  "include": [
    "Projects/**/*.ts",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules",
    "playwright-report",
    "allure-report",
    "allure-results",
    "test-results",
    "dist"
  ]
}